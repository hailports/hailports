<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.claude-stack.public-case-study</string>

    <!-- DEFAULT-OFF. This serves a PUBLIC page. It does NOT auto-load and does NOT
         post anywhere. Owner arms it deliberately:
           cp tools/com.claude-stack.public-case-study.plist ~/Library/LaunchAgents/
           launchctl load ~/Library/LaunchAgents/com.claude-stack.public-case-study.plist
         Until then it stays disabled (Disabled=true, RunAtLoad=false). Bound to
         127.0.0.1 only; expose via a tunnel/reverse-proxy as a separate, deliberate step. -->
    <key>Disabled</key>
    <true/>
    <key>RunAtLoad</key>
    <false/>

    <key>ProgramArguments</key>
    <array>
        <string>/home/user/claude-stack/.venv/bin/python</string>
        <string>-u</string>
        <string>/home/user/claude-stack/tools/public_case_study_dashboard.py</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/home/user/claude-stack</string>
    <key>StandardOutPath</key>
    <string>/home/user/Library/Logs/claude-stack/public_case_study.log</string>
    <key>StandardErrorPath</key>
    <string>/home/user/Library/Logs/claude-stack/public_case_study.err.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>/home/user</string>
        <key>PYTHONPATH</key>
        <string>/home/user/claude-stack</string>
        <key>CLAUDE_STACK_DIR</key>
        <string>/home/user/claude-stack</string>
    </dict>
    <key>KeepAlive</key>
    <true/>
</dict>
</plist>
